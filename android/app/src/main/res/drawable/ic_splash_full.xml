<?xml version="1.0" encoding="utf-8"?>
<!--
  Combined splash image: mosque logo (top) + "نور القرآن" text (below).
  Designed to match the Flutter AppSplashScreen as closely as possible.
  Viewport is wide enough so Android centers it inside the icon circle.
-->
